generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Property {
  id             String   @id @default(cuid())
  title          String
  address        String
  price          Int
  operation      String   // "venta" | "alquiler"
  type           String   // "casa" | "departamento" | "terreno" | "local"
  description    String?
  bedrooms       Int?
  bathrooms      Int?
  area           Int?     // superficie en m²
  images         String[] @default([]) // URLs de las imágenes; la primera es la portada
  status         String   @default("activa")
  ownerId        String   // usuario que la publicó (propietario o agente)
  organizationId String?  // null = propietario directo; con valor = inmobiliaria
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([ownerId])
}